# Buat .env.mainnet (di folder mainnet-v2)
cat > mainnet-v2/.env.example << 'EOF'
# BACKEND MAINNET
PORT=3001
NODE_ENV=production
BASE_URL=https://lab.tofarmer.xyz

# DATABASE
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key

# ALGORAND MAINNET
ALGOD_SERVER=https://mainnet-api.algonode.cloud
ALGOD_PORT=443
NETWORK=mainnet
TOF_ASA_ID=3558306283

# AUTH
JWT_SECRET=your_secret_key_min_32_characters
EOF