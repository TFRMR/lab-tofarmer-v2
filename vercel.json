{
  "version": 2,
  "builds": [
    {
      "src": "tofarmer-web/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "tofarmer-api/wrangler.toml",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "tofarmer-api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/tofarmer-web/$1"
    }
  ]
}